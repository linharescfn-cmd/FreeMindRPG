<section class="container-contact">
	<h1>Crie sua conta</h1>
	<p>Cadastre-se para comprar, publicar e acompanhar suas obras favoritas.</p>

	<form>
		<label for="nome-cadastro">Nome</label>
		<input type="text" id="nome-cadastro" placeholder="Seu nome completo" required>

		<label for="email-cadastro">E-mail</label>
		<input type="email" id="email-cadastro" placeholder="voce@email.com" required>

		<label for="senha-cadastro">Senha</label>
		<input type="password" id="senha-cadastro" placeholder="Crie uma senha" required>

		<button type="submit" id="botao-enviar">Criar conta</button>
	</form>
</section>
