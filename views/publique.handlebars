<section class="cadastro-page">
    <div class="cadastro-square">
        <div class="cadastro-form-card">
            <h1>Publique sua obra</h1>
            <p>Preencha os dados abaixo para enviar seu material para revisão.</p>

            <form class="cadastro-form">
                <label for="titulo-obra">Título da obra</label>
                <input type="text" id="titulo-obra" placeholder="Ex.: Crônicas da Noite" required>

                <label for="descricao-obra">Descrição</label>
                <textarea id="descricao-obra" placeholder="Descreva seu sistema, cenário ou aventura" required></textarea>

                <label for="preco-obra">Preço sugerido (R$)</label>
                <input type="number" id="preco-obra" min="0" step="0.01" placeholder="0,00" required>

                <button type="submit" class="cadastro-submit">ENVIAR PARA AVALIAÇÃO</button>
            </form>
        </div>
    </div>
</section>