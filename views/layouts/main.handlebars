    <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon_io%20(1)/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon_io%20(1)/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon_io%20(1)/favicon-16x16.png">
    <link rel="icon" href="/img/favicon_io%20(1)/favicon.ico">
    <link rel="manifest" href="/img/favicon_io%20(1)/site.webmanifest">
